msgid "Click <gui>Copy Special</gui> from the <gui>Edit</gui> submenu of the <gui>Main menu</gui>; or"
msgstr "Кликните на <gui>Умножи нарочит</gui> из подменија <gui>Уреди</gui> у <gui>Главном менију</gui>; или"

